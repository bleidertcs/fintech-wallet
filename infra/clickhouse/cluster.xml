<clickhouse>
    <distributed_ddl>
        <profile>default</profile>
    </distributed_ddl>


    <macros>
        <shard>01</shard>
        <replica>clickhouse</replica>
    </macros>

    <remote_servers>
        <cluster>
            <shard>
                <replica>
                    <host>clickhouse</host>
                    <port>9000</port>
                </replica>
            </shard>
        </cluster>
    </remote_servers>
</clickhouse>
